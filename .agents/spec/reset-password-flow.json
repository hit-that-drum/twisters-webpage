{
  "version": "2.0.0",
  "flow": "modal_forgot_password_token_verified",
  "endpoints": [
    {
      "method": "POST",
      "path": "/authentication/request-reset",
      "auth": { "type": "none", "required": false }
    },
    {
      "method": "POST",
      "path": "/authentication/verify-reset-token",
      "auth": { "type": "none", "required": false }
    },
    {
      "method": "POST",
      "path": "/authentication/reset-password",
      "auth": { "type": "none", "required": false }
    }
  ],
  "request": {
    "contentType": "application/json",
    "body": {
      "email": {
        "type": "string",
        "required": true,
        "format": "email"
      },
      "newPassword": {
        "type": "string",
        "required": true,
        "minLength": 1
      },
      "token": {
        "type": "string",
        "required": true
      }
    }
  },
  "execution": [
    "request_reset_token",
    "verify_reset_token",
    "validate_email_and_new_password_and_token",
    "hash_password_with_bcrypt_salt_rounds_10",
    "consume_token_single_use",
    "update_users_password_by_user_id",
    "return_result"
  ],
  "responses": {
    "200": {
      "message": "비밀번호가 성공적으로 변경되었습니다."
    },
    "400": {
      "error": "이메일/토큰/비밀번호 유효성 오류"
    },
    "404": {
      "error": "해당 사용자를 찾을 수 없습니다."
    },
    "500": {
      "error": "서버 에러가 발생했습니다."
    }
  },
  "frontend": {
    "route": "/signin",
    "uiSurface": "forgot_password_modal",
    "sourceFiles": [
      "frontend/src/pages/Login.tsx",
      "frontend/src/App.tsx"
    ],
    "apiCall": {
      "sequence": [
        "/authentication/request-reset",
        "/authentication/verify-reset-token",
        "/authentication/reset-password"
      ],
      "authorizationHeader": "optional"
    }
  },
  "constraints": {
    "emailBasedReset": true,
    "tokenBasedReset": true,
    "tokenStoredHashed": true,
    "tokenExpiryMinutes": 30,
    "tokenSingleUse": true,
    "resetTokenTableRequired": true,
    "singleActor": "email_owner_with_valid_token"
  }
}
