{
  "version": "1.0.0",
  "flow": "jwt_authenticated_password_reset",
  "endpoint": {
    "method": "POST",
    "path": "/authentication/reset-password",
    "auth": {
      "type": "bearer_jwt",
      "required": true,
      "resolver": "passport-jwt"
    }
  },
  "request": {
    "contentType": "application/json",
    "body": {
      "newPassword": {
        "type": "string",
        "required": true,
        "minLength": 1
      }
    }
  },
  "execution": [
    "validate_authenticated_user",
    "validate_new_password",
    "hash_password_with_bcrypt_salt_rounds_10",
    "update_users_password_by_authenticated_user_id",
    "return_result"
  ],
  "responses": {
    "200": {
      "message": "비밀번호가 성공적으로 변경되었습니다."
    },
    "400": {
      "error": "새 비밀번호를 입력해주세요."
    },
    "401": {
      "error": "인증된 사용자 정보가 없습니다."
    },
    "404": {
      "error": "해당 사용자를 찾을 수 없습니다."
    },
    "500": {
      "error": "서버 에러가 발생했습니다."
    }
  },
  "frontend": {
    "route": "/reset-password",
    "sourceFiles": [
      "frontend/src/pages/Login.tsx",
      "frontend/src/pages/ResetPassword.tsx",
      "frontend/src/App.tsx"
    ],
    "apiCall": {
      "path": "/authentication/reset-password",
      "method": "POST",
      "body": [
        "newPassword"
      ],
      "authorizationHeader": "Bearer <token from localStorage>"
    }
  },
  "constraints": {
    "emailBasedReset": false,
    "resetTokenTableRequired": false,
    "singleActor": "currently_authenticated_user"
  }
}
